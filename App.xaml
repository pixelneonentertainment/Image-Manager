<Application x:Class="GorselYoneticisi.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GorselYoneticisi"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Default theme resources; individual themes will be merged at runtime -->
        <ResourceDictionary>
            <Color x:Key="LeftPanelBg_Color">#2A2A3E</Color>
            <Color x:Key="MainBg_Color">#1E1E2E</Color>
            <Color x:Key="CardBg_Color">#23232B</Color>
            <Color x:Key="Text_Color">#FFFFFF</Color>
            <Color x:Key="SecondaryText_Color">#AAAAAA</Color>
            <Color x:Key="Accent_Color">#6C63FF</Color>

            <SolidColorBrush x:Key="LeftPanelBackground" Color="{StaticResource LeftPanelBg_Color}" />
            <SolidColorBrush x:Key="WindowBackground" Color="{StaticResource MainBg_Color}" />
            <SolidColorBrush x:Key="CardBackground" Color="{StaticResource CardBg_Color}" />
            <SolidColorBrush x:Key="TextForeground" Color="{StaticResource Text_Color}" />
            <SolidColorBrush x:Key="SecondaryForeground" Color="{StaticResource SecondaryText_Color}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent_Color}" />

            <SolidColorBrush x:Key="ButtonBackground" Color="#3A3A50" />
            <SolidColorBrush x:Key="ButtonForeground" Color="White" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
