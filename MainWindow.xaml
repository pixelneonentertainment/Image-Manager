<Window x:Class="GorselYoneticisi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GorselYoneticisi"
        Title="Görsel Yöneticisi" Height="700" Width="1100"
        Icon="app_logo.ico" 
        Background="{DynamicResource WindowBackground}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Klasör adını sade göstermek için değer dönüştürücü -->
        <local:PathToFolderConverter x:Key="PathToFolderConverter"/>

        <!-- Modern Buton Stili (Hover ve Pasif durumlarını yönetir) -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Fare Üzerine Geldiğinde (Hover) -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <!-- Buton Pasif Olduğunda (Tarama Esnası) -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#333344"/>
                                <Setter Property="Foreground" Value="#888888"/>
                                <Setter Property="Cursor" Value="No"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 3 KOLONLU YAPI: Sürükleme çubuğu için ortada 4 piksel genişliğinde kolon oluşturuldu [3.4] -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="180" MaxWidth="400"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SOL PANEL (DockPanel sayesinde imza her zaman en alttadır) -->
        <DockPanel Grid.Column="0" Background="{DynamicResource LeftPanelBackground}">

            <!-- EN ALTA SABİTLENEN İMZA ALANI -->
            <StackPanel DockPanel.Dock="Bottom" Margin="10,15,10,15" HorizontalAlignment="Center">
                <TextBlock Text="Pixel Neon Entertainment" 
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="11" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="© 2026 Tüm Hakları Saklıdır" 
                           Foreground="{DynamicResource SecondaryForeground}"
                           FontSize="9" 
                           HorizontalAlignment="Center"
                           Opacity="0.5"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- DİĞER KONTROLLER (ScrollViewer ile taşmalar engellenmiştir) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="🖼 Görsel Yöneticisi" Foreground="{DynamicResource TextForeground}"
                               FontSize="16" FontWeight="Bold" Margin="15,20,15,15"/>

                    <ComboBox x:Name="themeCombo" Margin="10,5" Padding="6" SelectionChanged="ThemeCombo_SelectionChanged"
                              Background="{DynamicResource ButtonBackground}" Foreground="#2A2A2A">
                        <ComboBoxItem Tag="Theme1" Content="Tema 1 - Koyu" IsSelected="True"/>
                        <ComboBoxItem Tag="Theme2" Content="Tema 2 - Okyanus" />
                        <ComboBoxItem Tag="Theme3" Content="Tema 3 - Zümrüt Yeşili" />
                        <ComboBoxItem Tag="Theme4" Content="Tema 4 - Şeker Pembe" />
                        <ComboBoxItem Tag="Theme5" Content="Tema 5 - Rengarenk" />
                    </ComboBox>

                    <Button x:Name="btnTara" Content="🖥️  Tüm Bilgisayarı Tara" Click="BtnTara_Click" Style="{StaticResource ModernButtonStyle}"/>

                    <Button x:Name="btnDiskSec" Content="💽  Sürücüleri Seç" Click="BtnDiskSec_Click" Style="{StaticResource ModernButtonStyle}"/>

                    <Button x:Name="btnTumunuSec" Content="✔️  Tümünü Seç" Click="BtnTumunuSec_Click" Style="{StaticResource ModernButtonStyle}"/>

                    <Button x:Name="btnSecimiKaldir" Content="❌  Seçimi Kaldır" Click="BtnSecimiKaldir_Click" Style="{StaticResource ModernButtonStyle}"/>

                    <Button x:Name="btnYinelenenleri" Content="🔁  Yinelenenler" Click="BtnYinelenenleri_Click" Style="{StaticResource ModernButtonStyle}"/>

                    <Button x:Name="btnSil" Content="🗑️  Seçilenleri Sil" Click="BtnSil_Click" Style="{StaticResource ModernButtonStyle}"/>

                    <Button x:Name="btnKopyala" Content="📋  Seçilenleri Kopyala" Click="BtnKopyala_Click" Style="{StaticResource ModernButtonStyle}"/>

                    <!-- Seçili görsel sayısı ve MB bilgisi -->
                    <TextBlock x:Name="lblSecili" Foreground="{DynamicResource AccentBrush}"
                               FontSize="12" Margin="15,20,15,5"
                               TextWrapping="Wrap" Text="0 görsel seçili"/>

                    <!-- Bulunan toplam görsel sayısı -->
                    <TextBlock x:Name="lblDurum" Foreground="{DynamicResource SecondaryForeground}"
                               FontSize="12" Margin="15,5,15,5"
                               TextWrapping="Wrap" Text="Hazır."/>

                    <!-- YÜKLEME ÇUBUĞU (Tarama veya eşleştirme esnasında görünür olur) -->
                    <ProgressBar x:Name="scanProgressBar" 
                                 Height="5" 
                                 Margin="15,4,15,8" 
                                 Background="{DynamicResource CardBackground}" 
                                 Foreground="{DynamicResource AccentBrush}" 
                                 BorderThickness="0"
                                 Visibility="Collapsed"/>

                    <!-- LIGHTROOM TARZI DISK VE KLASÖR AĞACI (TreeView) -->
                    <Border Margin="15,8,15,15" Padding="6" Background="{DynamicResource CardBackground}" CornerRadius="6">
                        <TreeView x:Name="trvDosyalar" Height="180" Background="{DynamicResource CardBackground}" BorderThickness="0"
                                  SelectedItemChanged="TrvDosyalar_SelectedItemChanged"
                                  MouseDoubleClick="TrvDosyalar_MouseDoubleClick">
                            <TreeView.Resources>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Style.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#6C63FF" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3A3A50" />
                                    </Style.Resources>
                                </Style>

                                <HierarchicalDataTemplate DataType="{x:Type local:FolderNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="2">
                                        <!-- İkon Alanı -->
                                        <Grid Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <!-- Sürücü Simgesi -->
                                            <Path Fill="#90A4AE" Data="M19 13H5c-1.1 0-2 .9-2 2v2c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-2c0-1.1-.9-2-2-2zm-1 4H6v-2h12v2z" 
                                                  Visibility="{Binding DriveIconVisibility}"/>
                                            <!-- Klasör Simgesi -->
                                            <Path Fill="#FFCA28" Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-0.9-2-2-2h-8l-2-2z"
                                                  Visibility="{Binding FolderIconVisibility}"/>
                                        </Grid>
                                        <!-- Sürücü / Klasör Adı -->
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                            <!-- Sağ Tık Menüsü -->
                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Klasörü Aç" Click="OpenInExplorer_Click"/>
                                    <MenuItem Header="Konum Yolunu Kopyala" Click="CopyPath_Click"/>
                                </ContextMenu>
                            </TreeView.ContextMenu>
                        </TreeView>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- SÜRÜKLEME ÇUBUĞU (GridSplitter - Paneli Yana Doğru Genişletir) -->
        <GridSplitter Grid.Column="1" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch" 
                      Background="{DynamicResource LeftPanelBackground}"
                      Cursor="SizeWE" />

        <!-- SAĞ PANEL -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ÜST BAR: Sayfalama ve Gelişmiş Filtreleme Seçenekleri -->
            <StackPanel Grid.Row="0" Margin="10,8,10,5">
                <!-- Sayfalama Satırı -->
                <Grid Margin="0,0,0,8">
                    <TextBlock x:Name="lblSayfa" Foreground="{DynamicResource SecondaryForeground}" 
                           FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left" 
                           Text="Sayfa 0 / 0 (0 görsel)"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnIlkSayfa" Content="|&lt;" Margin="6,0" Padding="6,4" Click="BtnIlkSayfa_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" BorderThickness="0"/>
                        <Button x:Name="btnOncekiSayfa" Content="&lt;" Margin="6,0" Padding="6,4" Click="BtnOncekiSayfa_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" BorderThickness="0"/>
                        <Button x:Name="btnSonrakiSayfa" Content="&gt;" Margin="6,0" Padding="6,4" Click="BtnSonrakiSayfa_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" BorderThickness="0"/>
                        <Button x:Name="btnSonSayfa" Content="&gt;|" Margin="6,0" Padding="6,4" Click="BtnSonSayfa_Click" Background="{DynamicResource ButtonBackground}" Foreground="{DynamicResource ButtonForeground}" BorderThickness="0"/>
                    </StackPanel>
                </Grid>

                <!-- GELİŞMİŞ FİLTRELEME BARI -->
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                    <!-- Dosya Türü Süzgeci -->
                    <TextBlock Text="Tür:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                    <ComboBox x:Name="filterType" Width="85" Margin="0,0,15,0" Padding="4,2" FontSize="11" SelectionChanged="Filter_Changed" Background="{DynamicResource ButtonBackground}" Foreground="#2A2A2A">
                        <ComboBoxItem Content="Tümü" IsSelected="True"/>
                        <ComboBoxItem Content="JPG"/>
                        <ComboBoxItem Content="PNG"/>
                        <ComboBoxItem Content="GIF"/>
                        <ComboBoxItem Content="WebP"/>
                    </ComboBox>

                    <!-- Boyut Süzgeci -->
                    <TextBlock Text="Boyut:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                    <ComboBox x:Name="filterSize" Width="110" Margin="0,0,15,0" Padding="4,2" FontSize="11" SelectionChanged="Filter_Changed" Background="{DynamicResource ButtonBackground}" Foreground="#2A2A2A">
                        <ComboBoxItem Content="Her Boyut" IsSelected="True"/>
                        <ComboBoxItem Content="&lt; 500 KB"/>
                        <ComboBoxItem Content="500 KB - 5 MB"/>
                        <ComboBoxItem Content="5 MB - 20 MB"/>
                        <ComboBoxItem Content="&gt; 20 MB"/>
                    </ComboBox>

                    <!-- Değiştirme Tarihi Süzgeci -->
                    <TextBlock Text="Tarih:" Foreground="{DynamicResource SecondaryForeground}" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                    <ComboBox x:Name="filterDate" Width="105" Margin="0,0,15,0" Padding="4,2" FontSize="11" SelectionChanged="Filter_Changed" Background="{DynamicResource ButtonBackground}" Foreground="#2A2A2A">
                        <ComboBoxItem Content="Her Tarih" IsSelected="True"/>
                        <ComboBoxItem Content="Son 24 Saat"/>
                        <ComboBoxItem Content="Son 7 Gün"/>
                        <ComboBoxItem Content="Son 30 Gün"/>
                        <ComboBoxItem Content="Son 1 Yıl"/>
                    </ComboBox>
                </WrapPanel>
            </StackPanel>

            <!-- Görsel Listeleme Alanı -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="gorselPanel" Margin="10"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>