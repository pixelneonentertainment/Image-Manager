<Window x:Class="GorselYoneticisi.DiskSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sürücü Seç" Height="300" Width="400" WindowStartupLocation="CenterOwner" Background="#2A2A3E">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Tarayacağınız sürücüleri seçin:" Foreground="White" Margin="5"/>
            <ScrollViewer Height="180">
                <StackPanel x:Name="drivesPanel" Margin="5"/>
            </ScrollViewer>
            <CheckBox x:Name="chkTumunuSec" Content="Tümünü seç" Foreground="White" Margin="5"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnIptal" Content="İptal" Width="90" Margin="5" Click="BtnIptal_Click" Background="#7F8C8D" Foreground="White"/>
            <Button x:Name="btnTamam" Content="Tara" Width="90" Margin="5" Click="BtnTamam_Click" Background="#4CAF50" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>